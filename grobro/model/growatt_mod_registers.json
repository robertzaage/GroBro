{
  "config_registers": {
    "data_interval": {
      "growatt": {
        "register_no": 4,
        "data": { "data_type": "INT" }
      },
      "homeassistant": {
        "publish": true,
        "name": "Update Interval",
        "type": "number",
        "unit_of_measurement": "min",
        "min": 0,
        "max": 60,
        "step": 1
      }
    },
    "mqtt_port": {
      "growatt": {
        "register_no": 18,
        "data": { "data_type": "INT" }
      },
